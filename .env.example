# ── LLM providers (at least one recommended) ────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Optional: pin a specific Gemini model (default tries gemini-2.5-flash-lite, 2.5-flash, 3.1-flash-lite, 3.5-flash)
GEMINI_MODEL=

# ── Voice providers (fallback order: elevenlabs → openai → google → azure → polly → playht → cartesia → coqui-local)
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
PLAYHT_API_KEY=
PLAYHT_USER_ID=
CARTESIA_API_KEY=

# ── Image generation ────────────────────────────────────────
STABILITY_API_KEY=
REPLICATE_API_TOKEN=

# ── Music & SFX ─────────────────────────────────────────────
FREESOUND_API_KEY=
MUSICGEN_ENDPOINT=

# ── 3D assets ───────────────────────────────────────────────
SKETCHFAB_API_TOKEN=
# Poly Haven needs no key (free API)

# ── Server ──────────────────────────────────────────────────
PORT=4000
OUTPUT_DIR=./output
BLENDER_PATH=blender
